{
  "expo": {
    "slug": "rick-and-morty-wiki",
    "name": "Rick and Morty Wiki",
    "version": "1.0.0",
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "experiments": {
      "tsconfigPaths": true
    },
    "plugins": [
      "expo-router",
      "expo-splash-screen"
    ],
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/ricksanchez.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.lobodev.rickandmortywiki"
    },
    "scheme": "rickandmortywiki",
    "splash": {
      "image": "./assets/rick-and-morty-splash.jpg",
      "resizeMode": "cover",
      "backgroundColor": "#000000",
      "mdpi": "./assets/rick-and-morty-splash",
      "hdpi": "./assets/rick-and-morty-splash",
      "xhdpi": "./assets/rick-and-morty-splash",
      "xxhdpi": "./assets/rick-and-morty-splash",
      "xxxhdpi": "./assets/rick-and-morty-splash"
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "174f0a1a-31fc-4686-9b78-0ed8be2f6bcd"
      }
    }
  }
}
